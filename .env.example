# --- Vercel KV (Redis) ---
# Provision a KV / Upstash Redis store from the Vercel dashboard
# (Storage -> Create -> KV). Vercel injects these automatically on deploy;
# for local dev run `vercel env pull .env.local` or paste them here.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Admin CMS ---
# Password protecting the hidden /admin-cms project editor.
# Set a strong value in the Vercel project's Environment Variables.
ADMIN_CMS_PASSWORD=change-me

# --- Contact form (Resend) ---
# Create a key at https://resend.com (API Keys). Required to send mail.
RESEND_API_KEY=
# Where contact submissions are delivered.
CONTACT_TO=info@gamgroup.it
# Sender — MUST be on a domain verified in Resend (e.g. noreply@gamgroup.it).
# Leave as onboarding@resend.dev only for testing (delivers to the account owner).
CONTACT_FROM=GAM Group <onboarding@resend.dev>

